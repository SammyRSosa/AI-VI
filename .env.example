# ────────────────────────────────────────────────────
# .env.example — copia este archivo a .env y rellena
#                tus API keys reales.
# ────────────────────────────────────────────────────

# ── Proveedor LLM (elige uno) ──────────────────────
# Opción 1: Google Gemini (gratuito)
GOOGLE_API_KEY=tu_google_api_key_aqui

# Opción 2: Groq (gratuito con rate limit)
GROQ_API_KEY=tu_groq_api_key_aqui

# Opción 3: OpenAI
OPENAI_API_KEY=tu_openai_api_key_aqui

# Opción 4: Anthropic
ANTHROPIC_API_KEY=tu_anthropic_api_key_aqui

# ── Configuración del LLM ─────────────────────────
# Proveedor activo: "gemini", "groq", "openai", "anthropic"
LLM_PROVIDER=gemini

# Modelo específico a usar
LLM_MODEL=gemini/gemini-1.5-flash

# Temperatura (0.0 = determinístico, recomendado para evaluación)
LLM_TEMPERATURE=0.0

# Máximo de tokens en la respuesta del LLM
LLM_MAX_TOKENS=256

# ── Caché ─────────────────────────────────────────
# Directorio donde se guarda el caché en disco
LLM_CACHE_DIR=data/llm_cache

# ── Experimentos ──────────────────────────────────
# Semilla aleatoria para reproducibilidad
RANDOM_SEED=42
